# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai
# Sign up for free and generate your API key
OPENROUTER_API_KEY=your_api_key_here

# Optional: Specify model (defaults to available models)
# OPENROUTER_MODEL=meta-llama/llama-2-70b-chat

# Optional: Specify port
# FLASK_PORT=5000

# Optional: Debug mode (set to False in production)
# FLASK_ENV=development
